{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "manager",
        "viewer"
      ],
      "default": "viewer"
    },
    "organisation_id": {
      "type": "string",
      "title": "Organisation ID"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "pending",
        "inactive"
      ],
      "default": "active"
    }
  },
  "required": [
    "organisation_id"
  ]
}